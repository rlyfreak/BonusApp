<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Единая Бонусная Система">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label
                Text="Единая Бонусная Система"
                FontSize="24"
                FontAttributes="Bold" />

            <Label
                Text="Учебный прототип мобильного приложения"
                FontSize="16" />

            <Frame Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Что будет реализовано:" FontAttributes="Bold" />
                    <Label Text="• регистрация пользователя" />
                    <Label Text="• выпуск карт лояльности" />
                    <Label Text="• просмотр бонусного баланса" />
                    <Label Text="• история транзакций" />
                    <Label Text="• уведомления об операциях" />
                </VerticalStackLayout>
            </Frame>

            <Button
                x:Name="OpenCardsButton"
                Text="Открыть список карт"
                Clicked="OpenCardsButton_Clicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>