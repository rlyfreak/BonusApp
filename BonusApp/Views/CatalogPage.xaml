<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.CatalogPage"
    x:Name="CatalogPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#5E6883">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="CatalogBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#40475D" Offset="0.0" />
            <GradientStop Color="#5E6883" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource CatalogBackgroundBrush}">

        <!-- Основной контент -->
        <Grid Margin="0,0,0,110" RowDefinitions="Auto,Auto,*">

            <!-- Заголовок -->
            <Grid
                Grid.Row="0"
                Padding="20,18,20,12"
                ColumnDefinitions="*">

                <Label
                    Text="Каталог карт"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White"
                    VerticalOptions="Center" />
            </Grid>

            <!-- Поиск -->
            <Border
                Grid.Row="1"
                Margin="20,0,20,12"
                Padding="0"
                Background="#2F3648"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14">

                <Grid ColumnDefinitions="Auto,*" Padding="14,8">
                    <Label
                        Text="⌕"
                        FontSize="18"
                        TextColor="#AEB6C9"
                        VerticalOptions="Center" />

                    <Entry
                        Grid.Column="1"
                        Text="{Binding SearchText}"
                        Placeholder="Название заведения"
                        PlaceholderColor="#AEB6C9"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="15"
                        Margin="10,0,0,0" />
                </Grid>
            </Border>

            <!-- Список каталога -->
            <Grid Grid.Row="2">

                <CollectionView
                    Margin="20,0,20,0"
                    ItemsSource="{Binding Items}"
                    IsVisible="{Binding HasItems}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,12"
                                Padding="14"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <!-- Логотип-заглушка -->
                                    <Border
                                        WidthRequest="58"
                                        HeightRequest="58"
                                        Background="#EEF2F8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 29"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="{Binding Name, StringFormat='{0:0}'}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#4A536B" />
                                    </Border>

                                    <!-- Текст -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="4"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#1F2430"
                                            LineBreakMode="TailTruncation" />

                                        <Label
                                            Text="Бонусная карта заведения"
                                            FontSize="13"
                                            TextColor="#6C7488" />
                                    </VerticalStackLayout>

                                    <!-- Кнопка -->
                                    <Button
                                        Grid.Column="2"
                                        Text="Добавить"
                                        Command="{Binding Source={x:Reference CatalogPageRoot}, Path=BindingContext.AddCardCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FFFFFF"
                                        TextColor="#2F3648"
                                        FontFamily="RubikMedium"
                                        FontSize="13"
                                        CornerRadius="12"
                                        HeightRequest="36"
                                        WidthRequest="96"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Пустое состояние -->
                <VerticalStackLayout
                    Margin="20,0,20,0"
                    IsVisible="{Binding IsEmpty}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="12">

                    <Label
                        Text="Доступных карт не найдено"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Возможно, все карты уже добавлены или поиск не дал результатов"
                        FontSize="14"
                        TextColor="#D7DDEA"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="260" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Нижняя навигация -->
        <controls:BottomNavBar
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="Catalog" />
    </Grid>
</ContentPage>