<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.CardDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#3F465B">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="DetailsBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#40475D" Offset="0.0" />
            <GradientStop Color="#5E6883" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource DetailsBackgroundBrush}">
        <ScrollView>
            <VerticalStackLayout Padding="20,14,20,30" Spacing="16">

                <!-- Шапка -->
                <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                    <Button
                        Text="←"
                        Clicked="BackButton_Clicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="22"
                        Padding="0"
                        WidthRequest="36"
                        HeightRequest="36" />

                    <Label
                        Grid.Column="1"
                        Text="Карта"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="White" />
                </Grid>

                <!-- Верхняя карта -->
                <Frame
                    Padding="18"
                    CornerRadius="22"
                    BackgroundColor="White"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="14">
                        <Frame
                            WidthRequest="58"
                            HeightRequest="58"
                            CornerRadius="29"
                            Padding="0"
                            BackgroundColor="#EEF2F8"
                            HasShadow="False"
                            HorizontalOptions="Center">

                            <Label
                                Text="◌"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                FontSize="26"
                                TextColor="#8BA071" />
                        </Frame>

                        <Label
                            Text="{Binding CafeName}"
                            HorizontalTextAlignment="Center"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#242A37" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Баланс -->
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label
                        Text="{Binding BonusValue}"
                        FontSize="44"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="бонусов"
                        FontSize="16"
                        TextColor="#D5DBE8"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- QR -->
                <Frame
                    Padding="18"
                    CornerRadius="22"
                    BackgroundColor="White"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="12">

                        <Grid
                            WidthRequest="220"
                            HeightRequest="220"
                            HorizontalOptions="Center"
                            BackgroundColor="White">

                            <!-- Заглушка под QR -->
                            <Frame
                                Padding="0"
                                CornerRadius="0"
                                BorderColor="#D6DBE5"
                                BackgroundColor="White"
                                HasShadow="False">

                                <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
                                    <BoxView Margin="12" Color="Black" />
                                    <BoxView Grid.Column="1" Margin="12" Color="White" />
                                    <BoxView Grid.Row="1" Margin="12" Color="White" />
                                    <BoxView Grid.Row="1" Grid.Column="1" Margin="12" Color="Black" />
                                </Grid>
                            </Frame>
                        </Grid>

                        <Label
                            Text="Подробности"
                            FontSize="14"
                            TextColor="#6C7488" />

                        <VerticalStackLayout Spacing="10">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label
                                    Text="Номер карты"
                                    FontSize="15"
                                    TextColor="#1F2430" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding CardNumberValue}"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="#1F2430" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label
                                    Text="QR-код"
                                    FontSize="15"
                                    TextColor="#1F2430" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding QrCodeValue}"
                                    FontSize="13"
                                    TextColor="#6C7488" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Кнопки деталей -->
                <VerticalStackLayout Spacing="10">
                    <Button
                        Text="История транзакций"
                        Command="{Binding OpenHistoryCommand}"
                        BackgroundColor="#FFFFFF"
                        TextColor="#31384A"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="14"
                        HeightRequest="52" />

                    <Button
                        Text="Условия"
                        Clicked="ConditionsButton_Clicked"
                        BackgroundColor="#4B5368"
                        TextColor="White"
                        FontSize="15"
                        CornerRadius="14"
                        HeightRequest="50" />

                    <Button
                        Text="Контакты"
                        Clicked="ContactsButton_Clicked"
                        BackgroundColor="#4B5368"
                        TextColor="White"
                        FontSize="15"
                        CornerRadius="14"
                        HeightRequest="50" />
                </VerticalStackLayout>

                <!-- Удаление -->
                <Button
                    Text="Удалить карту"
                    Clicked="DeleteCardButton_Clicked"
                    BackgroundColor="#F02828"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="14"
                    HeightRequest="54"
                    Margin="0,6,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>