<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.HistoryPage"
    x:Name="HistoryPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#5E6883">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="ProfileBackgroundBrush" StartPoint="0.18,0.08" EndPoint="0.82,1">
            <GradientStop Color="#4C5263" Offset="0.45" />
            <GradientStop Color="#9CAEE2" Offset="0.96" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource ProfileBackgroundBrush}">

        <!-- Основной контент -->
        <Grid Margin="0" RowDefinitions="Auto,Auto,Auto,*">

            <!-- Шапка -->
            <Grid
                x:Name="HeaderSlot"
                Grid.Row="0"
                IsClippedToBounds="True">

                <Grid
                    x:Name="HeaderContainer"
                    SizeChanged="HeaderContainer_SizeChanged"
                    Padding="27,15,27,0">

                    <Label
                        Text="История"
                        FontFamily="RubikMedium"
                        FontSize="36"
                        TextColor="#F3F6F9"
                        VerticalOptions="Center" />
                </Grid>
            </Grid>

            <!-- Поиск -->
            <Border
                Grid.Row="1"
                Margin="27,10,27,0"
                HeightRequest="51"
                Background="#313645"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 15">

                <Grid ColumnDefinitions="Auto,*" Padding="15,0">
                    <Image
                        Source="search.svg"
                        WidthRequest="21"
                        HeightRequest="21"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Aspect="AspectFit" />

                    <Entry
                        x:Name="SearchEntry"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Text="{Binding SearchText}"
                        TextChanged="SearchEntry_TextChanged"
                        Focused="SearchEntry_Focused"
                        Unfocused="SearchEntry_Unfocused"
                        Placeholder="Найти карту"
                        PlaceholderColor="#99F3F6F9"
                        TextColor="#F3F6F9"
                        BackgroundColor="Transparent"
                        FontFamily="RubikMedium"
                        FontSize="24"
                        HeightRequest="100"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center"
                        TranslationY="1" />
                </Grid>
            </Border>

            <!-- Фильтры -->
            <HorizontalStackLayout
                Grid.Row="2"
                Margin="27,10,27,0"
                Spacing="10">

                <Button
                    Text="Все"
                    Command="{Binding ShowAllCommand}"
                    WidthRequest="61"
                    HeightRequest="28"
                    Padding="0"
                    CornerRadius="15"
                    FontFamily="RubikMedium"
                    FontSize="16"
                    BackgroundColor="{Binding AllBackground}"
                    TextColor="{Binding AllTextColor}" />

                <Button
                    Text="Начисления"
                    Command="{Binding ShowAccrualCommand}"
                    WidthRequest="128"
                    HeightRequest="28"
                    Padding="0"
                    CornerRadius="15"
                    FontFamily="RubikMedium"
                    FontSize="16"
                    BackgroundColor="{Binding AccrualBackground}"
                    TextColor="{Binding AccrualTextColor}" />

                <Button
                    Text="Списания"
                    Command="{Binding ShowWriteOffCommand}"
                    WidthRequest="110"
                    HeightRequest="28"
                    Padding="0"
                    CornerRadius="15"
                    FontFamily="RubikMedium"
                    FontSize="16"
                    BackgroundColor="{Binding WriteOffBackground}"
                    TextColor="{Binding WriteOffTextColor}" />
            </HorizontalStackLayout>

            <!-- Список истории -->
            <Grid
                Grid.Row="3"
                Margin="0,18,0,0">

                <CollectionView
                    x:Name="HistoryCollectionView"
                    Margin="19,0,19,0"
                    IsGrouped="True"
                    ItemsSource="{Binding Groups}"
                    IsVisible="{Binding HasHistory}"
                    SelectionMode="None"
                    BackgroundColor="Transparent"
                    Scrolled="HistoryCollectionView_Scrolled">

                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Label
                                Text="{Binding Title}"
                                Margin="8,0,0,16"
                                FontFamily="RubikMedium"
                                FontSize="24"
                                TextColor="#E6F3F6F9" />
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,18"
                                HeightRequest="165"
                                Background="White"
                                Stroke="#80FFFFFF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="HistoryCard_Tapped" />
                                </Border.GestureRecognizers>
                                <Grid>

                                    <!-- Базовый fallback -->
                                    <Grid BackgroundColor="White">
                                        <Label
                                            Text="{Binding CafeName}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            FontFamily="RubikMedium"
                                            FontSize="28"
                                            TextColor="#2F3648" />
                                    </Grid>

                                    <!-- Готовые карточки-арты -->
                                    <Image
                                        Aspect="AspectFill"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill"
                                        IsVisible="False">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding CafeName}" Value="Калипсо">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="kalipsologo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding CafeName}" Value="Комод">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="komodlogo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding CafeName}" Value="Винил">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="vinyllogo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding CafeName}" Value="Редакция">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="redaktsyalogo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding CafeName}" Value="Знак">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="znaklogo.svg" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>

                                    <!-- Розмарин -->
                                    <Grid
                                        BackgroundColor="White"
                                        IsVisible="False">
                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid" Binding="{Binding CafeName}" Value="Розмарин">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Grid.Triggers>

                                        <Image
                                            Source="rozmarinlogo.svg"
                                            WidthRequest="64"
                                            HeightRequest="76"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            Aspect="AspectFit" />
                                    </Grid>

                                    <!-- Нижняя инфо-плашка -->
                                    <Border
                                        HeightRequest="85"
                                        VerticalOptions="End"
                                        Background="#E64C5263"
                                        Stroke="#80FFFFFF"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 0,0,20,20">

                                        <Grid
                                            Padding="14,10,14,12"
                                            ColumnDefinitions="*,Auto"
                                            RowDefinitions="Auto,Auto,Auto">

                                            <Label
                                                Grid.Row="0"
                                                Text="{Binding CafeName}"
                                                FontFamily="RubikMedium"
                                                FontSize="24"
                                                TextColor="#F3F6F9" />

                                            <Label
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Text="{Binding SignedAmount}"
                                                FontFamily="RubikMedium"
                                                FontSize="32"
                                                TextColor="{Binding AmountColorHex}"
                                                HorizontalTextAlignment="End" />

                                            <Label
                                                Grid.Row="1"
                                                Grid.Column="2"
                                                Margin="0,-12,0,0"
                                                Text="{Binding BalanceAfter, StringFormat='баланс: {0:0}'}"
                                                FontFamily="RubikMedium"
                                                FontSize="16"
                                                TextColor="#B3F3F6F9"
                                                HorizontalTextAlignment="End" />

                                            <Border
                                                Grid.Row="2"
                                                Margin="0,-30,0,0"
                                                Padding="12,3"
                                                HorizontalOptions="Start"
                                                Background="#F3F6F9"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 15">

                                                <Label
                                                    Text="{Binding Description}"
                                                    FontFamily="RubikMedium"
                                                    FontSize="16"
                                                    TextColor="#4C5263"
                                                    LineBreakMode="TailTruncation" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <Grid HeightRequest="140" BackgroundColor="Transparent" />
                    </CollectionView.Footer>
                </CollectionView>

                <!-- Пустое состояние -->
                <VerticalStackLayout
                    Margin="27,0,27,0"
                    IsVisible="{Binding IsHistoryEmpty}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="12">

                    <Label
                        Text="Пока ничего нет"
                        FontFamily="RubikMedium"
                        FontSize="22"
                        TextColor="#F3F6F9"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Здесь будут находиться ваши будущие транзакции"
                        FontFamily="RubikRegular"
                        FontSize="14"
                        TextColor="#D7DDEA"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="260" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Нижняя навигация -->
        <controls:BottomNavBar
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="History" />

        <!-- Sheet деталей операции -->
        <Grid
    x:Name="TransactionSheetOverlay"
    IsVisible="False"
    BackgroundColor="#CF000000">

            <Grid RowDefinitions="105,*">

                <!-- Верхняя зона для закрытия -->
                <Grid Grid.Row="0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseTransactionSheetCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Выезжающий лист -->
                <Border
            x:Name="TransactionSheetContainer"
            Grid.Row="1"
            Background="#4C5263"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 29,29,0,0"
            Padding="27,15,27,24"
            TranslationY="1200">

                    <ScrollView>
                        <VerticalStackLayout Spacing="15">

                            <!-- Верхняя строка -->
                            <Grid
                        HeightRequest="24"
                        ColumnDefinitions="Auto,*,Auto">

                                <Grid
                            WidthRequest="36"
                            HeightRequest="36"
                            HorizontalOptions="Start"
                            VerticalOptions="Center">

                                    <Image
                                Source="back_chevron.svg"
                                WidthRequest="15"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Aspect="AspectFit" />

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="CloseTransactionSheetButton_Tapped" />
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <Label
                            Grid.Column="1"
                            Text="{Binding SelectedRecord.Type}"
                            FontFamily="RubikMedium"
                            FontSize="20"
                            TextColor="#F3F6F9"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center"
                            VerticalOptions="Center" />

                                <BoxView
                            Grid.Column="2"
                            WidthRequest="36"
                            Opacity="0" />
                            </Grid>

                            <!-- Карточка -->
                            <Border
                        WidthRequest="358"
                        HeightRequest="165"
                        HorizontalOptions="Center"
                        Background="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">

                                <Grid>
                                    <Grid.Clip>
                                        <RoundRectangleGeometry
                                    Rect="0,0,358,165"
                                    CornerRadius="20" />
                                    </Grid.Clip>

                                    <!-- fallback -->
                                    <Grid BackgroundColor="White">
                                        <Label
                                    Text="{Binding SelectedRecord.CafeName}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    FontFamily="RubikMedium"
                                    FontSize="28"
                                    TextColor="#2F3648" />
                                    </Grid>

                                    <!-- готовые карточки -->
                                    <Image
                                Aspect="AspectFill"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                IsVisible="False">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding SelectedRecord.CafeName}" Value="Калипсо">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="kalipsologo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding SelectedRecord.CafeName}" Value="Комод">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="komodlogo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding SelectedRecord.CafeName}" Value="Винил">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="vinyllogo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding SelectedRecord.CafeName}" Value="Редакция">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="redaktsyalogo.svg" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Image" Binding="{Binding SelectedRecord.CafeName}" Value="Знак">
                                                <Setter Property="IsVisible" Value="True" />
                                                <Setter Property="Source" Value="znaklogo.svg" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>

                                    <!-- розмарин -->
                                    <Grid
                                BackgroundColor="White"
                                IsVisible="False">
                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid" Binding="{Binding SelectedRecord.CafeName}" Value="Розмарин">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Grid.Triggers>

                                        <Image
                                    Source="rozmarinlogo.svg"
                                    WidthRequest="64"
                                    HeightRequest="76"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Aspect="AspectFit" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Сумма -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label
                            Text="{Binding SelectedRecord.AmountTitle}"
                            FontFamily="RubikMedium"
                            FontSize="24"
                            TextColor="#F3F6F9"
                            VerticalOptions="Center" />

                                <Label
                            Grid.Column="1"
                            Text="{Binding SelectedRecord.LargeSignedAmount}"
                            FontFamily="RubikMedium"
                            FontSize="32"
                            TextColor="{Binding SelectedRecord.AmountColorHex}"
                            HorizontalTextAlignment="End"
                            VerticalOptions="Center" />
                            </Grid>

                            <!-- Заголовок деталей -->
                            <Label
                        Text="Детали операции"
                        FontFamily="RubikMedium"
                        FontSize="20"
                        TextColor="#CCF3F6F9" />

                            <!-- Блок деталей -->
                            <Border
                        WidthRequest="358"
                        HeightRequest="360"
                        HorizontalOptions="Center"
                        Background="#303645"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        Padding="15,10,15,15">

                                <Grid RowDefinitions="Auto,1,Auto,1,Auto,1,Auto,1,Auto,1,Auto">

                                    <!-- Баланс до -->
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <Label
                                    Text="Баланс до"
                                    Padding="0,0,0,10"
                                    FontFamily="RubikMedium"
                                    FontSize="18"
                                    TextColor="#CCF3F6F9" />
                                        <Label
                                    Grid.Column="1"
                                    Text="{Binding SelectedRecord.BalanceBefore}"
                                            Padding="0,0,0,0"
                                    FontFamily="RubikRegular"
                                    FontSize="18"
                                    TextColor="#F3F6F9" />
                                    </Grid>

                                    <BoxView Grid.Row="1" HeightRequest="1" Color="#80F3F6F9" />

                                    <!-- Баланс после -->
                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                        <Label
                                    Text="Баланс после"
                                            Padding="0,10,0,10"
                                    FontFamily="RubikMedium"
                                    FontSize="18"
                                    TextColor="#CCF3F6F9" />
                                        <Label
                                    Grid.Column="1"
                                    Text="{Binding SelectedRecord.BalanceAfter}"
                                            Padding="0,10,0,0"
                                    FontFamily="RubikRegular"
                                    FontSize="18"
                                    TextColor="#F3F6F9" />
                                    </Grid>

                                    <BoxView Grid.Row="3" HeightRequest="1" Color="#80F3F6F9" />

                                    <!-- Время -->
                                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
                                        <Label
                                    Text="Время"
                                            Padding="0,10,0,10"
                                    FontFamily="RubikMedium"
                                    FontSize="18"
                                    TextColor="#CCF3F6F9" />
                                        <Label
                                    Grid.Column="1"
                                    Text="{Binding SelectedRecord.FullDateTimeText}"
                                            Padding="0,10,0,0"
                                    FontFamily="RubikRegular"
                                    FontSize="18"
                                    TextColor="#F3F6F9" />
                                    </Grid>

                                    <BoxView Grid.Row="5" HeightRequest="1" Color="#80F3F6F9" />

                                    <!-- Заведение -->
                                    <Grid Grid.Row="6" RowDefinitions="Auto,Auto">
                                        <Label
                                    Text="Заведение"
                                            Padding="0,10,0,5"
                                    FontFamily="RubikMedium"
                                    FontSize="18"
                                    TextColor="#CCF3F6F9" />
                                        <Label
                                    Grid.Row="1"
                                    Margin="0,0,0,10"
                                    Text="{Binding SelectedRecord.VenueAddress}"
                                    FontFamily="RubikRegular"
                                    FontSize="13"
                                    TextColor="#F3F6F9"
                                    LineBreakMode="WordWrap" />
                                    </Grid>

                                    <BoxView Grid.Row="7" HeightRequest="1" Color="#80F3F6F9" />

                                    <!-- ID операции -->
                                    <Grid Grid.Row="8" ColumnDefinitions="*,Auto,Auto">
                                        <Label
                                    Text="ID операции"
                                            Padding="0,10,0,10"
                                    FontFamily="RubikMedium"
                                    FontSize="18"
                                    TextColor="#CCF3F6F9" />
                                        <Label
                                    Grid.Column="1"
                                    Margin="0,0,5,0"
                                    Text="{Binding SelectedRecord.OperationCode}"
                                    FontFamily="RubikRegular"
                                    FontSize="18"
                                    TextColor="#F3F6F9"
                                    VerticalOptions="Center" />
                                        <Button
                                    Grid.Column="2"
                                    Text="⧉"
                                    Clicked="CopyOperationIdButton_Clicked"
                                    BackgroundColor="Transparent"
                                    TextColor="#F3F6F9"
                                    Padding="0"
                                    WidthRequest="20"
                                    HeightRequest="20" />
                                    </Grid>

                                    <BoxView Grid.Row="9" HeightRequest="1" Color="#80F3F6F9" />

                                    <!-- Комментарий -->
                                    <Grid Grid.Row="10" RowDefinitions="Auto,Auto">
                                        <Label
                                    Text="Комментарий"
                                            Padding="0,10,0,0"
                                    FontFamily="RubikMedium"
                                    FontSize="18"
                                    TextColor="#CCF3F6F9" />
                                        <Label
                                    Grid.Row="1"
                                    Margin="0,5,0,0"
                                    Text="{Binding SelectedRecord.Comment}"
                                    FontFamily="RubikRegular"
                                    FontSize="13"
                                    TextColor="#F3F6F9" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>