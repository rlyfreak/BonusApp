<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.HistoryPage"
    x:Name="HistoryPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#5E6883">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="ProfileBackgroundBrush" StartPoint="0.18,0.08" EndPoint="0.82,1">
            <GradientStop Color="#4C5263" Offset="0.45" />
            <GradientStop Color="#9CAEE2" Offset="0.96" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource ProfileBackgroundBrush}">

        <!-- Основной контент -->
        <Grid Margin="0" RowDefinitions="Auto,Auto,Auto,*">

            <!-- Заголовок -->
            <Grid
                Grid.Row="0"
                Padding="20,18,20,12"
                ColumnDefinitions="*">

                <Label
                    Text="История"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White"
                    VerticalOptions="Center" />
            </Grid>

            <!-- Поиск -->
            <Border
                Grid.Row="1"
                Margin="20,0,20,12"
                Padding="0"
                Background="#2F3648"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14">

                <Grid ColumnDefinitions="Auto,*" Padding="14,8">
                    <Label
                        Text="⌕"
                        FontSize="18"
                        TextColor="#AEB6C9"
                        VerticalOptions="Center" />

                    <Entry
                        Grid.Column="1"
                        Text="{Binding SearchText}"
                        Placeholder="Найти карту"
                        PlaceholderColor="#AEB6C9"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="15"
                        Margin="10,0,0,0" />
                </Grid>
            </Border>

            <!-- Фильтры -->
            <HorizontalStackLayout
                Grid.Row="2"
                Margin="20,0,20,12"
                Spacing="8">

                <Button
                    Text="Все"
                    Command="{Binding ShowAllCommand}"
                    BackgroundColor="{Binding AllBackground}"
                    TextColor="{Binding AllTextColor}"
                    CornerRadius="14"
                    HeightRequest="34"
                    FontFamily="RubikMedium"
                    FontSize="14"
                    Padding="14,4" />

                <Button
                    Text="Начисления"
                    Command="{Binding ShowAccrualCommand}"
                    BackgroundColor="{Binding AccrualBackground}"
                    TextColor="{Binding AccrualTextColor}"
                    CornerRadius="14"
                    HeightRequest="34"
                    FontFamily="RubikMedium"
                    FontSize="14"
                    Padding="14,4" />

                <Button
                    Text="Списания"
                    Command="{Binding ShowWriteOffCommand}"
                    BackgroundColor="{Binding WriteOffBackground}"
                    TextColor="{Binding WriteOffTextColor}"
                    CornerRadius="14"
                    HeightRequest="34"
                    FontFamily="RubikMedium"
                    FontSize="14"
                    Padding="14,4" />
            </HorizontalStackLayout>

            <!-- Список истории -->
            <Grid Grid.Row="3">

                <CollectionView
                    Margin="20,0,20,0"
                    IsGrouped="True"
                    ItemsSource="{Binding Groups}"
                    IsVisible="{Binding HasHistory}">

                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Label
                                Text="{Binding Title}"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                Margin="0,8,0,10" />
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,12"
                                Padding="14"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference HistoryPageRoot}, Path=BindingContext.OpenTransactionDetailsCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">

                                    <Label
                                        Text="{Binding CafeName}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="#1F2430" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding SignedAmount}"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        TextColor="{Binding AmountColorHex}" />

                                    <Label
                                        Grid.Row="1"
                                        Text="{Binding Description}"
                                        FontSize="13"
                                        TextColor="#6C7488"
                                        Margin="0,6,0,0" />

                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding TimeText}"
                                        FontSize="12"
                                        TextColor="#6C7488"
                                        Margin="0,8,0,0"
                                        HorizontalTextAlignment="End" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Пустое состояние -->
                <VerticalStackLayout
                    Margin="20,0,20,0"
                    IsVisible="{Binding IsHistoryEmpty}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="12">

                    <Label
                        Text="Пока ничего нет"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Здесь будут находиться ваши будущие транзакции"
                        FontSize="14"
                        TextColor="#D7DDEA"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="260" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Нижняя навигация -->
        <controls:BottomNavBar
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="History" />

        <!-- Sheet деталей операции -->
        <Grid
            x:Name="TransactionSheetOverlay"
            IsVisible="False"
            BackgroundColor="#CC000000">

            <Grid RowDefinitions="88,*">

                <!-- верхняя зона для закрытия -->
                <Grid Grid.Row="0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseTransactionSheetCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- выезжающий лист -->
                <Border
                    x:Name="TransactionSheetContainer"
                    Grid.Row="1"
                    Background="#4C5263"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 29,29,0,0"
                    Padding="20,14,20,28"
                    TranslationY="1200">

                    <ScrollView>
                        <VerticalStackLayout Spacing="16">

                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button
                                    Text="←"
                                    Clicked="CloseTransactionSheetButton_Clicked"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="22"
                                    Padding="0"
                                    WidthRequest="36"
                                    HeightRequest="36" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding SelectedRecord.Type}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    FontSize="20"
                                    FontFamily="RubikMedium"
                                    TextColor="White" />

                                <BoxView Grid.Column="2" WidthRequest="36" />
                            </Grid>

                            <Border
                                HeightRequest="165"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20">

                                <Grid>
                                    <Label
                                        Text="{Binding SelectedRecord.CafeName}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        FontSize="28"
                                        FontFamily="RubikMedium"
                                        TextColor="#1F2430" />
                                </Grid>
                            </Border>

                            <Label
                                Text="{Binding SelectedRecord.AmountTitle}"
                                FontSize="24"
                                FontFamily="RubikMedium"
                                TextColor="White" />

                            <Label
                                Text="{Binding SelectedRecord.LargeSignedAmount}"
                                FontSize="32"
                                FontFamily="RubikMedium"
                                TextColor="{Binding SelectedRecord.AmountColorHex}"
                                HorizontalOptions="End" />

                            <Label
                                Text="Детали операции"
                                FontSize="20"
                                FontFamily="RubikMedium"
                                TextColor="#CCF3F6F9" />

                            <Border
                                Background="#303645"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 15"
                                Padding="14">

                                <VerticalStackLayout Spacing="12">

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Баланс до" FontSize="18" FontFamily="RubikMedium" TextColor="#CCF3F6F9" />
                                        <Label Grid.Column="1" Text="{Binding SelectedRecord.BalanceBefore}" FontSize="18" TextColor="White" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#80F3F6F9" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Баланс после" FontSize="18" FontFamily="RubikMedium" TextColor="#CCF3F6F9" />
                                        <Label Grid.Column="1" Text="{Binding SelectedRecord.BalanceAfter}" FontSize="18" TextColor="White" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#80F3F6F9" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Время" FontSize="18" FontFamily="RubikMedium" TextColor="#CCF3F6F9" />
                                        <Label Grid.Column="1" Text="{Binding SelectedRecord.FullDateTimeText}" FontSize="18" TextColor="White" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#80F3F6F9" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Заведение" FontSize="18" FontFamily="RubikMedium" TextColor="#CCF3F6F9" />
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding SelectedRecord.VenueAddress}"
                                            FontSize="13"
                                            TextColor="White"
                                            HorizontalTextAlignment="End"
                                            MaximumWidthRequest="180" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#80F3F6F9" />

                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <Label Text="ID операции" FontSize="18" FontFamily="RubikMedium" TextColor="#CCF3F6F9" />
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding SelectedRecord.OperationCode}"
                                            FontSize="18"
                                            TextColor="White"
                                            Margin="0,0,8,0" />
                                        <Button
                                            Grid.Column="2"
                                            Text="⧉"
                                            Clicked="CopyOperationIdButton_Clicked"
                                            BackgroundColor="Transparent"
                                            TextColor="White"
                                            Padding="0"
                                            WidthRequest="24"
                                            HeightRequest="24" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#80F3F6F9" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Комментарий" FontSize="18" FontFamily="RubikMedium" TextColor="#CCF3F6F9" />
                                        <Label Grid.Column="1" Text="{Binding SelectedRecord.Comment}" FontSize="13" TextColor="White" />
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>