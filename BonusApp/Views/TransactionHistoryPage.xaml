<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.TransactionHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="История транзакций">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <VerticalStackLayout Spacing="6">
            <Label
                Text="История транзакций"
                FontSize="26"
                FontAttributes="Bold" />

            <Label
                x:Name="CardInfoLabel"
                Text="Карта"
                FontSize="14"
                Opacity="0.8" />
        </VerticalStackLayout>

        <CollectionView
            x:Name="TransactionsCollectionView"
            Grid.Row="1"
            Margin="0,20,0,0">

            <CollectionView.EmptyView>
                <Label
                    Text="По этой карте пока нет транзакций."
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,14" Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="{Binding Type}"
                                FontSize="18"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding BonusAmount, StringFormat='Количество бонусов: {0}'}"
                                FontSize="15" />

                            <Label
                                Text="{Binding Description, StringFormat='Описание: {0}'}"
                                FontSize="15" />

                            <Label
                                Text="{Binding Date, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}"
                                FontSize="14"
                                Opacity="0.8" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>