<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#5E6883">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="ProfileBackgroundBrush" StartPoint="0.18,0.08" EndPoint="0.82,1">
            <GradientStop Color="#4C5263" Offset="0.45" />
            <GradientStop Color="#9CAEE2" Offset="0.96" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource ProfileBackgroundBrush}">

        <ScrollView Margin="0">
            <VerticalStackLayout Padding="27,15,27,120" Spacing="10">

                <!-- Заголовок -->
                <Label
                    Text="Профиль"
                    FontSize="36"
                    FontFamily="RubikMedium"
                    TextColor="#F3F6F9" />

                <!-- Номер телефона -->
                <Border
                    Margin="0,10,0,0"
                    Padding="16,10"
                    Background="#303645"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15">

                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultScale="1"
                            PressedScale="0.97"
                            PressedOpacity="0.96"
                            PressedAnimationDuration="90"
                            DefaultAnimationDuration="110" />
                    </Border.Behaviors>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label
                            Text="Номер телефона"
                            FontSize="18"
                            FontFamily="RubikMedium"
                            TextColor="#CCF3F6F9" />

                        <Label
                            Grid.Row="1"
                            Text="{Binding PhoneNumber}"
                            FontSize="18"
                            FontFamily="RubikRegular"
                            TextColor="#F3F6F9" />

                        <Label
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Text="›"
                            FontSize="26"
                            TextColor="#80F3F6F9"
                            VerticalOptions="Center" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="PhoneCardTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Email -->
                <Border
                    Padding="16,10"
                    Background="#303645"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15">

                    <Border.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultScale="1"
                            PressedScale="0.97"
                            PressedOpacity="0.96"
                            PressedAnimationDuration="90"
                            DefaultAnimationDuration="110" />
                    </Border.Behaviors>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label
                            Text="Электронная почта"
                            FontSize="18"
                            FontFamily="RubikMedium"
                            TextColor="#CCF3F6F9" />

                        <Label
                            Grid.Row="1"
                            Text="{Binding Email}"
                            FontSize="18"
                            FontFamily="RubikRegular"
                            TextColor="#F3F6F9"
                            LineBreakMode="TailTruncation" />

                        <Label
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Text="›"
                            FontSize="26"
                            TextColor="#80F3F6F9"
                            VerticalOptions="Center" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="EmailCardTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Персональные данные -->
                <Border
                    Margin="0,10,0,0"
                    Padding="0"
                    Background="#303645"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15">

                    <VerticalStackLayout Spacing="0">

                        <Label
                            Margin="16,14,16,10"
                            Text="Персональные данные"
                            FontSize="18"
                            FontFamily="RubikMedium"
                            TextColor="#F3F6F9" />

                        <BoxView HeightRequest="1" Color="#80F3F6F9" />

                        <Grid Padding="16,10" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label
                                Text="Фамилия"
                                FontSize="18"
                                FontFamily="RubikMedium"
                                TextColor="#CCF3F6F9" />

                            <Label
                                Grid.Row="1"
                                Text="{Binding LastName}"
                                FontSize="18"
                                FontFamily="RubikRegular"
                                TextColor="#F3F6F9" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="8,0,8,0" Color="#80F3F6F9" />

                        <Grid Padding="16,10" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label
                                Text="Имя"
                                FontSize="18"
                                FontFamily="RubikMedium"
                                TextColor="#CCF3F6F9" />

                            <Label
                                Grid.Row="1"
                                Text="{Binding FirstName}"
                                FontSize="18"
                                FontFamily="RubikRegular"
                                TextColor="#F3F6F9" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="8,0,8,0" Color="#80F3F6F9" />

                        <Grid Padding="16,10" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label
                                Text="Отчество"
                                FontSize="18"
                                FontFamily="RubikMedium"
                                TextColor="#CCF3F6F9" />

                            <Label
                                Grid.Row="1"
                                Text="{Binding MiddleName}"
                                FontSize="18"
                                FontFamily="RubikRegular"
                                TextColor="#F3F6F9" />
                        </Grid>

                        <BoxView HeightRequest="1" Margin="8,0,8,0" Color="#80F3F6F9" />

                        <Grid Padding="16,10" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label
                                Text="Дата рождения"
                                FontSize="18"
                                FontFamily="RubikMedium"
                                TextColor="#CCF3F6F9" />

                            <Label
                                Grid.Row="1"
                                Text="{Binding BirthDateText}"
                                FontSize="18"
                                FontFamily="RubikRegular"
                                TextColor="#F3F6F9" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Редактировать -->
                <Button
                    Margin="0,10,0,0"
                    Text="Редактировать"
                    Clicked="EditProfileButton_Clicked"
                    BackgroundColor="#F3F6F9"
                    TextColor="#4C5263"
                    FontFamily="RubikMedium"
                    FontSize="16"
                    CornerRadius="29"
                    HeightRequest="39">
                    <Button.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultScale="1"
                            PressedScale="0.97"
                            PressedOpacity="0.96"
                            PressedAnimationDuration="90"
                            DefaultAnimationDuration="110" />
                    </Button.Behaviors>
                </Button>

                <!-- Выйти -->
                <Button
                    Text="Выйти из аккаунта"
                    Clicked="LogoutButton_Clicked"
                    BackgroundColor="#303645"
                    TextColor="#F3F6F9"
                    FontFamily="RubikMedium"
                    FontSize="16"
                    CornerRadius="29"
                    HeightRequest="39">
                    <Button.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultScale="1"
                            PressedScale="0.97"
                            PressedOpacity="0.96"
                            PressedAnimationDuration="90"
                            DefaultAnimationDuration="110" />
                    </Button.Behaviors>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Нижняя навигация -->
        <controls:BottomNavBar
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="Profile" />
    </Grid>
</ContentPage>