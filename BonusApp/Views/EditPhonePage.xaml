<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.EditPhonePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#5E6883">

	<ContentPage.Resources>
		<LinearGradientBrush x:Key="ProfileBackgroundBrush" StartPoint="0.18,0.08" EndPoint="0.82,1">
			<GradientStop Color="#4C5263" Offset="0.45" />
			<GradientStop Color="#9CAEE2" Offset="0.96" />
		</LinearGradientBrush>
	</ContentPage.Resources>

	<Grid Background="{StaticResource ProfileBackgroundBrush}">

		<!-- Назад -->
		<Image
            Source="back_chevron.svg"
            WidthRequest="15"
            HeightRequest="24"
            Margin="27,25,0,0"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            Aspect="Fill">

			<Image.GestureRecognizers>
				<TapGestureRecognizer Tapped="BackChevron_Tapped" />
			</Image.GestureRecognizers>
		</Image>

		<!-- Заголовок -->
		<Label
            Text="Ваш номер телефона"
            WidthRequest="273"
            Margin="27,69,0,0"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            FontFamily="RubikMedium"
            FontSize="26"
            TextColor="#F3F6F9"
            HorizontalTextAlignment="Start"
            LineBreakMode="NoWrap" />

		<!-- Подзаголовок -->
		<Label
            Text="Используется для добавления карт и списания бонусов в заведениях"
            WidthRequest="279"
            Margin="27,105,0,0"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            FontFamily="RubikRegular"
            FontSize="16"
            TextColor="#CCF3F6F9"
            HorizontalTextAlignment="Start"
            LineBreakMode="WordWrap"
            MaxLines="2" />

		<!-- Поле телефона -->
		<Border
            WidthRequest="358"
            HeightRequest="51"
            Margin="27,163,0,0"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            Background="#303645"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 15">

			<Grid Padding="16,0">
				<Entry
                    Text="{Binding PhoneNumber}"
                    Keyboard="Telephone"
                    BackgroundColor="Transparent"
                    TextColor="#F3F6F9"
                    FontFamily="RubikRegular"
                    FontSize="18"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    ClearButtonVisibility="Never"
                    Placeholder="+79991234567"
                    PlaceholderColor="#99F3F6F9" />
			</Grid>
		</Border>

		<!-- Сохранить -->
		<Button
            Text="Сохранить"
            Clicked="SaveButton_Clicked"
            WidthRequest="358"
            HeightRequest="39"
            Margin="27,0,0,25"
            HorizontalOptions="Start"
            VerticalOptions="End"
            BackgroundColor="#F3F6F9"
            TextColor="#4C5263"
            FontFamily="RubikMedium"
            FontSize="16"
            CornerRadius="29" />
	</Grid>
</ContentPage>