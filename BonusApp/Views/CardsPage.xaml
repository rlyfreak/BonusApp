<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.CardsPage"
    x:Name="CardsPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#3F465B">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="ProfileBackgroundBrush" StartPoint="0.18,0.08" EndPoint="0.82,1">
            <GradientStop Color="#4C5263" Offset="0.45" />
            <GradientStop Color="#9CAEE2" Offset="0.96" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource ProfileBackgroundBrush}">

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Шапка -->
            <Grid
                Grid.Row="0"
                Padding="27,15,27,0"
                ColumnDefinitions="*,Auto">

                <Label
                    Text="Мои карты"
                    FontFamily="RubikMedium"
                    FontSize="36"
                    TextColor="#F3F6F9"
                    VerticalOptions="Center" />

                <Border
                    Grid.Column="1"
                    WidthRequest="51"
                    HeightRequest="45"
                    Background="#F3F6F9"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15"
                    VerticalOptions="Center">

                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Offset="0,2"
                            Radius="7.5"
                            Opacity="0.25" />
                    </Border.Shadow>

                    <Grid>
                        <Image
                            Source="notification_bell.svg"
                            WidthRequest="22"
                            HeightRequest="27"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Aspect="AspectFit" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenNotificationsPageCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>
            </Grid>

            <!-- Поиск -->
            <Border
                Grid.Row="1"
                Margin="27,10,27,0"
                HeightRequest="51"
                Background="#313645"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 15">

                <Grid ColumnDefinitions="Auto,*" Padding="15,0">
                    <Image
                        Source="search.svg"
                        WidthRequest="21"
                        HeightRequest="21"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Aspect="AspectFit" />

                    <Grid
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalOptions="Center">

                        <Entry
                        Text="{Binding SearchText}"
                        Placeholder="Найти карту"
                        PlaceholderColor="#99F3F6F9"
                        TextColor="#F3F6F9"
                        BackgroundColor="Transparent"
                        FontFamily="RubikMedium"
                        FontSize="24"
                        HeightRequest="100"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center"
                        TranslationY="1" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Список карт / пустое состояние -->
            <Grid Grid.Row="2" Margin="0,18,0,0">

                <CollectionView
                    Margin="27,0,27,0"
                    ItemsSource="{Binding Cards}"
                    IsVisible="{Binding HasCards}"
                    SelectionMode="None"
                    BackgroundColor="Transparent">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid
            WidthRequest="358"
            HeightRequest="165"
            Margin="0,0,0,18"
            HorizontalOptions="Center">

                                <!-- ГОТОВЫЕ КАРТОЧКИ-АССЕТЫ -->
                                <Border
                WidthRequest="358"
                HeightRequest="165"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Background="Transparent"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                IsVisible="{Binding UseFullCardArt}">

                                    <Grid>
                                        <Image
                        Source="{Binding FullCardArtSource}"
                        Aspect="AspectFill"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Scale="{Binding FullCardArtScale}" />

                                        <Border
                        WidthRequest="{Binding BadgeWidth}"
                        HeightRequest="29"
                        Margin="0,0,9,8"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Background="{Binding BadgeBackgroundColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        ZIndex="10">

                                            <Label
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span
                                        Text="{Binding BonusBalance}"
                                        FontFamily="RubikMedium"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                        <Span
                                        Text=" бонусов"
                                        FontFamily="RubikRegular"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- РОЗМАРИН -->
                                <Border
                WidthRequest="358"
                HeightRequest="165"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Background="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                IsVisible="{Binding UseCenteredLogoCard}">

                                    <Grid>
                                        <Image
                        Source="{Binding CenterLogoSource}"
                        WidthRequest="64"
                        HeightRequest="76"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Aspect="AspectFit" />

                                        <Border
                        WidthRequest="{Binding BadgeWidth}"
                        HeightRequest="29"
                        Margin="0,0,9,8"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Background="{Binding BadgeBackgroundColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        ZIndex="10">

                                            <Label
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span
                                        Text="{Binding BonusBalance}"
                                        FontFamily="RubikMedium"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                        <Span
                                        Text=" бонусов"
                                        FontFamily="RubikRegular"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- FALLBACK -->
                                <Border
                WidthRequest="358"
                HeightRequest="165"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Background="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                IsVisible="{Binding UseFallbackCard}">

                                    <Grid>
                                        <Label
                        Text="{Binding CafeName}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontFamily="RubikMedium"
                        FontSize="28"
                        TextColor="{Binding FallbackTextColor}" />

                                        <Border
                        WidthRequest="{Binding BadgeWidth}"
                        HeightRequest="29"
                        Margin="0,0,9,8"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Background="{Binding BadgeBackgroundColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        ZIndex="10">

                                            <Label
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span
                                        Text="{Binding BonusBalance}"
                                        FontFamily="RubikMedium"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                        <Span
                                        Text=" бонусов"
                                        FontFamily="RubikRegular"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                    Command="{Binding Source={x:Reference CardsPageRoot}, Path=BindingContext.OpenCardDetailsCommand}"
                    CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <Grid HeightRequest="140" BackgroundColor="Transparent" />
                    </CollectionView.Footer>
                </CollectionView>

                <!-- Пустое состояние -->
                <Grid
                    Margin="27,0,27,0"
                    IsVisible="{Binding IsCardsEmpty}">

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="18">

                        <Label
                            Text="У вас пока нет бонусных карт."
                            FontSize="20"
                            FontFamily="RubikMedium"
                            TextColor="#F3F6F9"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Добавьте первую карту, чтобы начать пользоваться приложением."
                            FontSize="14"
                            FontFamily="RubikRegular"
                            TextColor="#D7DDEA"
                            HorizontalTextAlignment="Center"
                            MaximumWidthRequest="280" />

                        <Button
                            Text="Добавить карту"
                            Command="{Binding OpenCatalogPageCommand}"
                            BackgroundColor="#F3F6F9"
                            TextColor="#374056"
                            FontFamily="RubikMedium"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52"
                            WidthRequest="220" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Grid>

        <!-- Нижняя навигация -->
        <controls:BottomNavBar
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="Cards" />

        <!-- Bottom sheet -->
        <Grid
            x:Name="CardSheetOverlay"
            IsVisible="False"
            BackgroundColor="#66000000">

            <Grid RowDefinitions="72,*">

                <Grid Grid.Row="0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseCardSheetCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <Border
                    x:Name="SheetContainer"
                    Grid.Row="1"
                    Margin="0"
                    Padding="20,14,20,28"
                    Background="#5A627A"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28,28,0,0"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    TranslationY="1200">

                    <ScrollView>
                        <VerticalStackLayout Spacing="16">

                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button
                                    Text="←"
                                    Clicked="CloseSheetButton_Clicked"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="22"
                                    Padding="0"
                                    WidthRequest="36"
                                    HeightRequest="36" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding SelectedCard.CafeName}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="White" />

                                <BoxView Grid.Column="2" WidthRequest="36" />
                            </Grid>

                            <Border
                                Padding="18"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22">

                                <VerticalStackLayout Spacing="14">
                                    <Border
                                        WidthRequest="58"
                                        HeightRequest="58"
                                        Background="#EEF2F8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 29"
                                        HorizontalOptions="Center">

                                        <Label
                                            Text="◌"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            FontSize="26"
                                            TextColor="#8BA071" />
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label
                                    Text="{Binding SelectedCard.BonusBalance}"
                                    FontSize="44"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="бонусов"
                                    FontSize="16"
                                    TextColor="#D5DBE8"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <Border
                                Padding="18"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22">

                                <VerticalStackLayout Spacing="12">

                                    <Grid
                                        WidthRequest="220"
                                        HeightRequest="220"
                                        HorizontalOptions="Center"
                                        BackgroundColor="White">

                                        <Border
                                            Padding="0"
                                            Background="White"
                                            Stroke="#D6DBE5"
                                            StrokeThickness="1"
                                            StrokeShape="Rectangle">

                                            <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
                                                <BoxView Margin="12" Color="Black" />
                                                <BoxView Grid.Column="1" Margin="12" Color="White" />
                                                <BoxView Grid.Row="1" Margin="12" Color="White" />
                                                <BoxView Grid.Row="1" Grid.Column="1" Margin="12" Color="Black" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Label
                                        Text="Подробности"
                                        FontSize="14"
                                        TextColor="#6C7488" />

                                    <Border
                                        Padding="14,12"
                                        Background="#3F465B"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label
                                                Text="Номер карты"
                                                FontSize="15"
                                                TextColor="#D7DDEA" />

                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding SelectedCard.CardNumber}"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                TextColor="White" />
                                        </Grid>
                                    </Border>

                                    <Button
                                        Text="Условия"
                                        Clicked="ConditionsButton_Clicked"
                                        BackgroundColor="#3F465B"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        CornerRadius="14"
                                        HeightRequest="50" />

                                    <Button
                                        Text="Контакты"
                                        Clicked="ContactsButton_Clicked"
                                        BackgroundColor="#3F465B"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        CornerRadius="14"
                                        HeightRequest="50" />
                                </VerticalStackLayout>
                            </Border>

                            <Button
                                Text="Удалить карту"
                                Clicked="DeleteCardButton_Clicked"
                                BackgroundColor="#FF1E1E"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="16"
                                CornerRadius="16"
                                HeightRequest="54" />

                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>