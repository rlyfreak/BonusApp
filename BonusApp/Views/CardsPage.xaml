<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.CardsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Мои карты">

    <VerticalStackLayout Padding="20" Spacing="16">

        <Label
            Text="Мои бонусные карты"
            FontSize="26"
            FontAttributes="Bold" />

        <Label
            Text="Список подключённых карт заведений"
            FontSize="14"
            Opacity="0.8" />

        <Button
            Text="Добавить новую карту"
            Clicked="AddCardButton_Clicked" />

        <CollectionView
            x:Name="CardsCollectionView"
            SelectionMode="Single"
            SelectionChanged="CardsCollectionView_SelectionChanged">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,14" Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="{Binding CafeName}"
                                FontSize="20"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding CardNumber}"
                                FontSize="14" />

                            <Label
                                Text="{Binding BonusBalance}"
                                FontSize="16" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>