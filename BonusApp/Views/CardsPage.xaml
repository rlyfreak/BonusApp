<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.CardsPage"
    x:Name="CardsPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#3F465B">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="ProfileBackgroundBrush" StartPoint="0.18,0.08" EndPoint="0.82,1">
            <GradientStop Color="#4C5263" Offset="0.45" />
            <GradientStop Color="#9CAEE2" Offset="0.96" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource ProfileBackgroundBrush}">

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Шапка -->
            <Grid
                x:Name="HeaderSlot"
                Grid.Row="0"
                IsClippedToBounds="True">

                <Grid
                x:Name="HeaderContainer"
                SizeChanged="HeaderContainer_SizeChanged"
                Padding="27,15,27,0"
                ColumnDefinitions="*,Auto">

                    <Label
                    Text="Мои карты"
                    FontFamily="RubikMedium"
                    FontSize="36"
                    TextColor="#F3F6F9"
                    VerticalOptions="Center" />

                    <Border
                    Grid.Column="1"
                    WidthRequest="51"
                    HeightRequest="45"
                    Background="#F3F6F9"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15"
                    VerticalOptions="Center">

                        <Border.Shadow>
                            <Shadow
                            Brush="Black"
                            Offset="0,2"
                            Radius="7.5"
                            Opacity="0.25" />
                        </Border.Shadow>

                        <Grid>
                            <Image
                            Source="notification_bell.svg"
                            WidthRequest="22"
                            HeightRequest="27"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Aspect="AspectFit" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenNotificationsPageCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Поиск -->
            <Border
                Grid.Row="1"
                Margin="27,10,27,0"
                HeightRequest="51"
                Background="#313645"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 15">

                <Grid ColumnDefinitions="Auto,*" Padding="15,0">
                    <Image
                        Source="search.svg"
                        WidthRequest="21"
                        HeightRequest="21"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Aspect="AspectFit" />

                    <Grid
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalOptions="Center">

                        <Entry
                        x:Name="SearchEntry"
                        Text="{Binding SearchText}"
                        TextChanged="SearchEntry_TextChanged"
                        Focused="SearchEntry_Focused"
                            Unfocused="SearchEntry_Unfocused"
                        Placeholder="Найти карту"
                        PlaceholderColor="#99F3F6F9"
                        TextColor="#F3F6F9"
                        BackgroundColor="Transparent"
                        FontFamily="RubikMedium"
                        FontSize="24"
                        HeightRequest="100"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center"
                        TranslationY="1" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Список карт / пустое состояние -->
            <Grid Grid.Row="2" Margin="0,18,0,0">

                <CollectionView
                    x:Name="CardsCollectionView"
                    Margin="27,0,27,0"
                    ItemsSource="{Binding Cards}"
                    IsVisible="{Binding HasCards}"
                    SelectionMode="None"
                    BackgroundColor="Transparent"
                    Scrolled="CardsCollectionView_Scrolled">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid
        WidthRequest="358"
        HeightRequest="183"
        Margin="0,0,0,10"
        HorizontalOptions="Center">

                                <!-- ОБОЛОЧКА КАРТОЧКИ С ТЕНЬЮ -->
                                <Border
            Margin="4,4,4,14"
            Background="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">

                                    <Border.Shadow>
                                        <Shadow
                    Brush="#000000"
                    Offset="0,6"
                    Radius="12"
                    Opacity="0.25" />
                                    </Border.Shadow>

                                    <!-- ВНУТРЕННИЙ КОНТЕНТ -->
                                    <Grid>
                                        <Grid.Clip>
                                            <RoundRectangleGeometry
                        Rect="0,0,350,165"
                        CornerRadius="20" />
                                        </Grid.Clip>

                                        <!-- ГОТОВЫЕ КАРТОЧКИ-АССЕТЫ -->
                                        <Grid IsVisible="{Binding UseFullCardArt}">
                                            <Image
                        Source="{Binding FullCardArtSource}"
                        Aspect="AspectFill"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Scale="{Binding FullCardArtScale}" />

                                            <Border
                        WidthRequest="{Binding BadgeWidth}"
                        HeightRequest="29"
                        Margin="0,0,9,8"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Background="{Binding BadgeBackgroundColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        ZIndex="10">

                                                <Label
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span
                                        Text="{Binding BonusBalance}"
                                        FontFamily="RubikMedium"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                            <Span
                                        Text=" бонусов"
                                        FontFamily="RubikRegular"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </Border>
                                        </Grid>

                                        <!-- РОЗМАРИН -->
                                        <Grid
                    BackgroundColor="White"
                    IsVisible="{Binding UseCenteredLogoCard}">

                                            <Image
                        Source="{Binding CenterLogoSource}"
                        WidthRequest="64"
                        HeightRequest="76"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Aspect="AspectFit" />

                                            <Border
                        WidthRequest="{Binding BadgeWidth}"
                        HeightRequest="29"
                        Margin="0,0,9,8"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Background="{Binding BadgeBackgroundColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        ZIndex="10">

                                                <Label
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span
                                        Text="{Binding BonusBalance}"
                                        FontFamily="RubikMedium"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                            <Span
                                        Text=" бонусов"
                                        FontFamily="RubikRegular"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </Border>
                                        </Grid>

                                        <!-- FALLBACK -->
                                        <Grid
                    BackgroundColor="White"
                    IsVisible="{Binding UseFallbackCard}">

                                            <Label
                        Text="{Binding CafeName}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontFamily="RubikMedium"
                        FontSize="28"
                        TextColor="{Binding FallbackTextColor}" />

                                            <Border
                        WidthRequest="{Binding BadgeWidth}"
                        HeightRequest="29"
                        Margin="0,0,9,8"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Background="{Binding BadgeBackgroundColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15"
                        ZIndex="10">

                                                <Label
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span
                                        Text="{Binding BonusBalance}"
                                        FontFamily="RubikMedium"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                            <Span
                                        Text=" бонусов"
                                        FontFamily="RubikRegular"
                                        FontSize="16"
                                        TextColor="#F3F6F9" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Card_Tapped" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <Grid HeightRequest="140" BackgroundColor="Transparent" />
                    </CollectionView.Footer>
                </CollectionView>

                <!-- Пустое состояние -->
                <Grid
                    Margin="27,0,27,0"
                    IsVisible="{Binding IsCardsEmpty}">

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="18">

                        <Label
                            Text="У вас пока нет бонусных карт."
                            FontSize="20"
                            FontFamily="RubikMedium"
                            TextColor="#F3F6F9"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Добавьте первую карту, чтобы начать пользоваться приложением."
                            FontSize="14"
                            FontFamily="RubikRegular"
                            TextColor="#D7DDEA"
                            HorizontalTextAlignment="Center"
                            MaximumWidthRequest="280" />

                        <Button
                            Text="Добавить карту"
                            Command="{Binding OpenCatalogPageCommand}"
                            BackgroundColor="#F3F6F9"
                            TextColor="#374056"
                            FontFamily="RubikMedium"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52"
                            WidthRequest="220" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Grid>

        <!-- Нижняя навигация -->
        <controls:BottomNavBar
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="Cards" />

        <!-- Bottom sheet -->
        <Grid
            x:Name="CardSheetOverlay"
            IsVisible="False"
            BackgroundColor="#66000000">

            <Grid RowDefinitions="72,*">

                <Grid Grid.Row="0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseCardSheetCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <Border
    x:Name="SheetContainer"
    Grid.Row="1"
    Margin="0"
    Background="#4C5263"
    StrokeThickness="0"
    StrokeShape="RoundRectangle 29,29,0,0"
    HorizontalOptions="Fill"
    VerticalOptions="Fill"
    TranslationY="1200">

                    <ScrollView>
                        <VerticalStackLayout
            Padding="27,14,27,26"
            Spacing="20">

                            <!-- Верхняя строка -->
                            <Grid
                HeightRequest="28"
                ColumnDefinitions="Auto,*,Auto"
                VerticalOptions="Start">

                                <Grid
    WidthRequest="24"
    HeightRequest="24"
    HorizontalOptions="Start"
    VerticalOptions="Center">

                                    <Image
        Source="back_chevron.svg"
        WidthRequest="15"
        HeightRequest="24"
        HorizontalOptions="Center"
        VerticalOptions="Center"
        Aspect="AspectFit" />

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding CloseCardSheetCommand}" />
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <Label
                    Grid.Column="1"
                    Text="{Binding SelectedCard.CafeName}"
                    FontFamily="RubikMedium"
                    FontSize="20"
                    TextColor="White"
                    HorizontalTextAlignment="Center"
                    VerticalTextAlignment="Center"
                    LineBreakMode="TailTruncation"
                    VerticalOptions="Center" />

                                <!-- Баланс для центрирования заголовка -->
                                <BoxView
                    Grid.Column="2"
                    WidthRequest="15"
                    Opacity="0" />
                            </Grid>

                            <!-- Карта -->
                            <Border
                WidthRequest="358"
                HeightRequest="165"
                HorizontalOptions="Center"
                Background="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20">

                                <Grid>
                                    <Grid.Clip>
                                        <RoundRectangleGeometry
                            Rect="0,0,358,165"
                            CornerRadius="20" />
                                    </Grid.Clip>

                                    <!-- Полноценный арт карточки -->
                                    <Grid IsVisible="{Binding SelectedCard.UseFullCardArt}">
                                        <Image
                            Source="{Binding SelectedCard.FullCardArtSource}"
                            Aspect="AspectFill"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Scale="{Binding SelectedCard.FullCardArtScale}" />
                                    </Grid>

                                    <!-- Белая карточка с логотипом -->
                                    <Grid
                        BackgroundColor="White"
                        IsVisible="{Binding SelectedCard.UseCenteredLogoCard}">

                                        <Image
                            Source="{Binding SelectedCard.CenterLogoSource}"
                            WidthRequest="64"
                            HeightRequest="76"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Aspect="AspectFit" />
                                    </Grid>

                                    <!-- Fallback -->
                                    <Grid
                        BackgroundColor="White"
                        IsVisible="{Binding SelectedCard.UseFallbackCard}">

                                        <Label
                            Text="{Binding SelectedCard.CafeName}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            FontFamily="RubikMedium"
                            FontSize="28"
                            TextColor="{Binding SelectedCard.FallbackTextColor}" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Баланс -->
                            <VerticalStackLayout
                Spacing="0"
                HorizontalOptions="Center">

                                <Label
                    Text="{Binding SelectedCard.BonusBalance}"
                    FontFamily="RubikMedium"
                    FontSize="48"
                    TextColor="#F3F6F9"
                    HorizontalTextAlignment="Center" />

                                <Label
                    Text="бонусов"
                    Margin="0,-6,0,0"
                    FontFamily="RubikRegular"
                    FontSize="20"
                    TextColor="#CCF3F6F9"
                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- QR блок -->
                            <Border
                WidthRequest="358"
                HeightRequest="279"
                HorizontalOptions="Center"
                Background="White"
                Stroke="#B3A6A6A6"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 20">

                                <Grid>
                                    <Image
                        Source="{Binding SelectedCard.QrCodeSource}"
                        WidthRequest="227"
                        HeightRequest="227"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Aspect="AspectFit" />
                                </Grid>
                            </Border>

                            <!-- Подробности -->
                            <Label
                Text="Подробности"
                FontFamily="RubikMedium"
                FontSize="24"
                TextColor="#F3F6F9"
                HorizontalOptions="Start" />

                            <!-- Номер карты -->
                            <Border
    WidthRequest="349"
    HeightRequest="92"
    HorizontalOptions="Center"
    Background="#303645"
    StrokeThickness="0"
    StrokeShape="RoundRectangle 15"
    Padding="0">

                                <Grid
        Padding="15,8,0,15"
        RowDefinitions="Auto,Auto,Auto">

                                    <Label
            Grid.Row="0"
            Text="Номер карты"
            FontFamily="RubikMedium"
            FontSize="20"
            TextColor="#99F3F6F9" />

                                    <Label
            Grid.Row="2"
            Text="{Binding SelectedCard.CardNumber}"
            FontFamily="RubikRegular"
            FontSize="32"
            TextColor="#F3F6F9"
            VerticalOptions="Start" />
                                </Grid>
                            </Border>

                            <!-- Условия -->
                            <Border
                WidthRequest="349"
                HeightRequest="51"
                HorizontalOptions="Center"
                Background="#303645"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 15">

                                <Grid
                    Padding="16,0,15,0"
                    ColumnDefinitions="*,Auto">

                                    <Label
                        Text="Условия"
                        FontFamily="RubikMedium"
                        FontSize="20"
                        TextColor="#F3F6F9"
                        VerticalOptions="Center" />

                                    <Label
                        Grid.Column="1"
                        Text="›"
                        FontSize="28"
                        TextColor="#80F3F6F9"
                        VerticalOptions="Center" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="ConditionsRow_Tapped" />
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Контакты -->
                            <Border
                WidthRequest="349"
                HeightRequest="51"
                HorizontalOptions="Center"
                Background="#303645"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 15">

                                <Grid
                    Padding="16,0,15,0"
                    ColumnDefinitions="*,Auto">

                                    <Label
                        Text="Контакты"
                        FontFamily="RubikMedium"
                        FontSize="20"
                        TextColor="#F3F6F9"
                        VerticalOptions="Center" />

                                    <Label
                        Grid.Column="1"
                        Text="›"
                        FontSize="28"
                        TextColor="#80F3F6F9"
                        VerticalOptions="Center" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="ContactsRow_Tapped" />
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Удалить карту -->
                            <Button
                Text="Удалить карту"
                Clicked="DeleteCardButton_Clicked"
                WidthRequest="358"
                HeightRequest="39"
                HorizontalOptions="Center"
                BackgroundColor="#FF1200"
                TextColor="#F3F6F9"
                FontFamily="RubikMedium"
                FontSize="16"
                CornerRadius="29"
                Padding="0"
                Margin="0,0,0,8">
                                <Button.Behaviors>
                                    <toolkit:TouchBehavior
            DefaultScale="1"
            PressedScale="0.97"
            PressedOpacity="0.96"
            PressedAnimationDuration="90"
            DefaultAnimationDuration="110" />
                                </Button.Behaviors>
                            </Button>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>