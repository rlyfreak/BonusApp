<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BonusApp.Views.CardsPage"
    x:Name="CardsPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BonusApp.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#3F465B">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#40475D" Offset="0.0" />
            <GradientStop Color="#5E6883" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}" RowDefinitions="*,Auto">

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*">

            <!-- Верхняя часть -->
            <Grid
                Grid.Row="0"
                Padding="20,18,20,12"
                ColumnDefinitions="*,Auto">

                <Label
                    Text="Мои карты"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White"
                    VerticalOptions="Center" />

                <Border
                    Grid.Column="1"
                    WidthRequest="38"
                    HeightRequest="38"
                    Padding="0"
                    Background="#E8ECF4"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12">

                    <Button
                        Command="{Binding OpenNotificationsPageCommand}"
                        Text="🔔"
                        FontSize="16"
                        BackgroundColor="Transparent"
                        TextColor="#2F3648"
                        Padding="0" />
                </Border>
            </Grid>

            <!-- Поиск -->
            <Border
                Grid.Row="1"
                Margin="20,0,20,14"
                Padding="0"
                Background="#2F3648"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14">

                <Grid ColumnDefinitions="Auto,*" Padding="14,8">
                    <Label
                        Text="⌕"
                        FontSize="18"
                        TextColor="#AEB6C9"
                        VerticalOptions="Center" />

                    <Entry
                        Grid.Column="1"
                        Text="{Binding SearchText}"
                        Placeholder="Найти карту"
                        PlaceholderColor="#AEB6C9"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="15"
                        Margin="10,0,0,0" />
                </Grid>
            </Border>

            <!-- Список / пустое состояние -->
            <Grid Grid.Row="2">

                <CollectionView
                    Margin="20,0,20,0"
                    ItemsSource="{Binding Cards}"
                    IsVisible="{Binding HasCards}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,14"
                                Padding="14"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference CardsPageRoot}, Path=BindingContext.OpenCardDetailsCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*,Auto">

                                    <Border
                                        WidthRequest="54"
                                        HeightRequest="54"
                                        Background="#EEF2F8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 27"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="{Binding CafeName, StringFormat='{0:0}'}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#4A536B" />
                                    </Border>

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Margin="12,0,12,0"
                                        Spacing="4"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="{Binding CafeName}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#1F2430"
                                            LineBreakMode="TailTruncation" />

                                        <Label
                                            Text="{Binding CardNumber}"
                                            FontSize="13"
                                            TextColor="#6C7488" />

                                        <Label
                                            Text="{Binding BonusBalance, StringFormat='Баланс: {0}'}"
                                            FontSize="13"
                                            TextColor="#6C7488" />
                                    </VerticalStackLayout>

                                    <Border
                                        Grid.Column="2"
                                        Padding="10,4"
                                        Background="#5B6784"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10"
                                        VerticalOptions="End">

                                        <Label
                                            Text="{Binding BonusBalance, StringFormat='{0} бонусов'}"
                                            FontSize="11"
                                            FontAttributes="Bold"
                                            TextColor="White" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid
                    Margin="20,0,20,0"
                    IsVisible="{Binding IsCardsEmpty}">

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="18">

                        <Label
                            Text="У вас пока нет бонусных карт."
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Добавьте первую карту, чтобы начать пользоваться приложением."
                            FontSize="14"
                            TextColor="#D7DDEA"
                            HorizontalTextAlignment="Center"
                            MaximumWidthRequest="280" />

                        <Button
                            Text="Добавить карту"
                            Command="{Binding OpenAddCardPageCommand}"
                            BackgroundColor="White"
                            TextColor="#374056"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52"
                            WidthRequest="220" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Grid>

        <!-- НИЖНЯЯ НАВИГАЦИЯ -->
        <controls:BottomNavBar
            Grid.Row="1"
            Margin="16,0,16,12"
            VerticalOptions="End"
            CurrentTab="Cards" />

        <!-- OVERLAY С ЛИСТОМ -->
        <Grid
            x:Name="CardSheetOverlay"
            Grid.RowSpan="2"
            IsVisible="False"
            BackgroundColor="#66000000">

            <Grid RowDefinitions="72,*">

                <Grid Grid.Row="0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseCardSheetCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <Border
                    x:Name="SheetContainer"
                    Grid.Row="1"
                    Margin="0"
                    Padding="20,14,20,28"
                    Background="#5A627A"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28,28,0,0"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    TranslationY="1200">

                    <ScrollView>
                        <VerticalStackLayout Spacing="16">

                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button
                                    Text="←"
                                    Clicked="CloseSheetButton_Clicked"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="22"
                                    Padding="0"
                                    WidthRequest="36"
                                    HeightRequest="36" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding SelectedCard.CafeName}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="White" />

                                <BoxView Grid.Column="2" WidthRequest="36" />
                            </Grid>

                            <Border
                                Padding="18"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22">

                                <VerticalStackLayout Spacing="14">
                                    <Border
                                        WidthRequest="58"
                                        HeightRequest="58"
                                        Background="#EEF2F8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 29"
                                        HorizontalOptions="Center">

                                        <Label
                                            Text="◌"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            FontSize="26"
                                            TextColor="#8BA071" />
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label
                                    Text="{Binding SelectedCard.BonusBalance}"
                                    FontSize="44"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="бонусов"
                                    FontSize="16"
                                    TextColor="#D5DBE8"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <Border
                                Padding="18"
                                Background="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 22">

                                <VerticalStackLayout Spacing="12">

                                    <Grid
                                        WidthRequest="220"
                                        HeightRequest="220"
                                        HorizontalOptions="Center"
                                        BackgroundColor="White">

                                        <Border
                                            Padding="0"
                                            Background="White"
                                            Stroke="#D6DBE5"
                                            StrokeThickness="1"
                                            StrokeShape="Rectangle">

                                            <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
                                                <BoxView Margin="12" Color="Black" />
                                                <BoxView Grid.Column="1" Margin="12" Color="White" />
                                                <BoxView Grid.Row="1" Margin="12" Color="White" />
                                                <BoxView Grid.Row="1" Grid.Column="1" Margin="12" Color="Black" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Label
                                        Text="Подробности"
                                        FontSize="14"
                                        TextColor="#6C7488" />

                                    <Border
                                        Padding="14,12"
                                        Background="#3F465B"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label
                                                Text="Номер карты"
                                                FontSize="15"
                                                TextColor="#D7DDEA" />

                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding SelectedCard.CardNumber}"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                TextColor="White" />
                                        </Grid>
                                    </Border>

                                    <Button
                                        Text="Условия"
                                        Clicked="ConditionsButton_Clicked"
                                        BackgroundColor="#3F465B"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        CornerRadius="14"
                                        HeightRequest="50" />

                                    <Button
                                        Text="Контакты"
                                        Clicked="ContactsButton_Clicked"
                                        BackgroundColor="#3F465B"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        CornerRadius="14"
                                        HeightRequest="50" />
                                </VerticalStackLayout>
                            </Border>

                            <Button
                                Text="Удалить карту"
                                Clicked="DeleteCardButton_Clicked"
                                BackgroundColor="#FF1E1E"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="16"
                                CornerRadius="16"
                                HeightRequest="54" />

                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>